{% trans_default_domain 'products.category' %}

<nav>
	<div class="nav nav-tabs" id="nav-{{ form.trans.vars.id }}" role="tablist">
		{% for trans in form.trans %}
			<button class="nav-link{{ app.request.locale == trans.vars.value.local? ' active' : '' }}"
					id="nav-{{ trans.vars.id }}-tab" data-bs-toggle="tab"
					data-bs-target="#nav-{{ trans.vars.id }}"
					type="button" role="tab" aria-controls="nav-{{ trans.vars.id }}" aria-selected="true">
				{{ trans.vars.value.local|trans({}, 'messages') }}
			</button>
		{% endfor %}
	</div>
</nav>

<div class="tab-content mt-5" id="nav-{{ form.trans.vars.id }}Content">
	{% for trans in form.trans %}
		<div class="tab-pane fade{{ app.request.locale == trans.vars.value.local ? ' show active' : '' }}"
			 id="nav-{{ trans.vars.id }}" role="tabpanel"
			 aria-labelledby="nav-{{ trans.vars.id }}-tab">

			{# Локаль #}
			{{ form_row(trans.local) }}

			{# Название #}
			{{ form_row(trans.name, {
				label : 'admin.product.categoty.form.name'|trans, attr: { 'data-lang' : trans.vars.id ~ "_"~trans.vars.value.local  }
			}) }}

			{# Краткое описание #}
			{{ form_row(trans.description, {
				label: 'admin.product.categoty.form.desc'|trans
			}) }}
		</div>
	{% endfor %}

	{# Символьный код #}
	{{ form_row(form.info.url, { label : 'admin.form.url.label'|trans } ) }}

</div>



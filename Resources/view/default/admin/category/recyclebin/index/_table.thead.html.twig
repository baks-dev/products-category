{% trans_default_domain 'product.category' %}

<thead class="mb-5">

<tr class="text-start text-gray-400 fw-bolder fs-7 text-uppercase gs-0">

    <th class="w-10px pe-2 sorting_disabled" rowspan="1" colspan="1" style="width: 25px;">
    </th>

    {# Чекбокс #}
    <th class="w-10px pe-2 sorting_disabled" rowspan="1" colspan="1" style="width: 25px;" aria-label="
					">
        <div class="form-check form-check-sm form-check-custom me-3 pb-5">
            <label>
                <input class="form-check-input" type="checkbox" data-kt-check="true" data-kt-check-target="#kt_ecommerce_category_table .form-check-input" value="1">
            </label>
        </div>
    </th>

    <th class="min-w-300px pb-5 text-start" tabindex="0"
        aria-controls="kt_ecommerce_category_table"
        rowspan="1"
    >
        {# Название #}
        {{ 'admin.category.column.name'|trans }}
    </th>

    <th class="min-w-250px pb-5" tabindex="0" aria-controls="kt_ecommerce_category_table"
        rowspan="1" colspan="1" style="width: 799.9px;">
        {# Пользователь #}
        {{ 'user.label'|trans({}, 'messages') }}

    </th>

</tr>

</thead>

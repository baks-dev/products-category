{% trans_default_domain 'products.category' %}

<div class="modal-dialog modal-dialog-centered" style="max-width: 800px;">
    {{ form_start(form) }}
    <div class="modal-content">
        <div class="modal-header">

            <h5 class="modal-title">
                {# Заголовок модального окна #}
                {{ 'admin.form.restore.header'|trans }}

            </h5>

            <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                <span class="svg-icon svg-icon-2x"></span>
            </div>
        </div>

        <div class="modal-body">
            <h4>
                {# Вы уверены, что желаете восстановить #}
                {{ 'admin.form.restore.h4'|trans }} "{{ name }}"?
            </h4>
            <br>
            <p>
                {# Убедитесь, что выбран именно тот объект, который нужно удалить, и нажмите Удалить. Если вы не
                    желаете удалять выбранный объект, нажмите кнопку Отмена.  #}
                {{ 'restore.default.txt'|trans({}, 'messages') }}
            </p>
        </div>

        <div class="modal-footer">
            {# Отмена #}
            <div class="mb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    {{ 'btn.cancel'|trans({}, 'messages') }}
                </button>
            </div>
            {# Восстановить #}
            {{ form_row(form.restore, {label: 'btn.restore'|trans({}, 'messages') }) }}
        </div>
    </div>
    {{ form_end(form) }}
</div>
